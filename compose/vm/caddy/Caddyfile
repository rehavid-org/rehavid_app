# Reverse proxy con auto-TLS (Let's Encrypt) para REHAVID Operaciones.
# Caddy emite y renueva el certificado automáticamente una vez que el DNS
# de operaciones.rehavid.com.co apunte a la IP pública de la VM.

operaciones.rehavid.com.co {
	encode gzip zstd

	reverse_proxy django:5000 {
		header_up X-Forwarded-Proto {scheme}
		header_up X-Forwarded-Host {host}
	}

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		Referrer-Policy "strict-origin-when-cross-origin"
		X-Content-Type-Options "nosniff"
	}
}

# Fallback HTTP: sirve /health/ en claro (para verificar por IP antes del DNS)
# y redirige el resto a HTTPS una vez el DNS ya resuelve.
:80 {
	@health path /health /health/
	reverse_proxy @health django:5000

	redir https://{host}{uri} permanent
}
